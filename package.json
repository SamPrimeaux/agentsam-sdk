    "test": "node scripts/smoke.mjs",
    "smoke": "node scripts/smoke.mjs",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/SamPrimeaux/agentsam-sdk.git"
  },
  "keywords": [
    "ai",
